# Copy to your deployment environment (systemd unit, Docker env, shell export, etc.)
# Do NOT commit real values.

# --- CCAvenue (get these from your CCAvenue dashboard) ---
CCAVENUE_MERCHANT_ID=your_merchant_id
CCAVENUE_ACCESS_CODE=your_access_code
CCAVENUE_WORKING_KEY=your_working_key
# UAT/test: https://test.ccavenue.com/transaction/transaction.do?command=initiateTransaction
# Production: https://secure.ccavenue.com/transaction/transaction.do?command=initiateTransaction
CCAVENUE_TRANSACTION_URL=https://test.ccavenue.com/transaction/transaction.do?command=initiateTransaction
# Must be a publicly reachable HTTPS URL whitelisted in the CCAvenue dashboard
CCAVENUE_REDIRECT_URL=https://your-domain/payment/response
CCAVENUE_CANCEL_URL=https://your-domain/payment/response

# --- App ---
SERVER_PORT=8091

# --- MySQL ---
DB_URL=jdbc:mysql://localhost:3306/student_fees?useSSL=false&serverTimezone=Asia/Kolkata&allowPublicKeyRetrieval=true
DB_USERNAME=studentfees
DB_PASSWORD=your_db_password
